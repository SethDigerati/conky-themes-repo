# Conky Themes API Configuration Template
# Copy this file to .env and fill in your own API credentials
# The .env file is gitignored - it will not be committed to version control

# ============================================
# Last.fm API Configuration
# ============================================
# Get your API key at: https://www.last.fm/api/account/create
LASTFM_API_KEY=YOUR_API_KEY_HERE
LASTFM_USERNAME=YOUR_LASTFM_USERNAME_HERE

# ============================================
# OpenWeatherMap API Configuration
# ============================================
# Get your free API key at: https://openweathermap.org/api
WEATHER_API_KEY=YOUR_API_KEY_HERE
WEATHER_NAME=Default
WEATHER_UNITS=metric
